rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema Validation Helpers
    function isValidAdmin(data) {
      return data.keys().hasAll(['id', 'email', 'name', 'role', 'status'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 128
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 200
        && data.role is string && (data.role == "Super Admin" || data.role == "Manager" || data.role == "Staff")
        && data.status is string && (data.status == "Active" || data.status == "Inactive");
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['id', 'blockName', 'floor', 'roomNo', 'seatsTotal', 'seatsBooked', 'seatsReserved', 'status', 'updatedAt'])
        && data.keys().size() == 9
        && data.id is string && data.id.size() <= 128
        && data.blockName is string && data.blockName.size() <= 200
        && data.floor is int
        && data.roomNo is string && data.roomNo.size() <= 50
        && data.seatsTotal is int && data.seatsTotal >= 0
        && data.seatsBooked is int && data.seatsBooked >= 0
        && data.seatsReserved is int && data.seatsReserved >= 0
        && data.status is string && (data.status == "Available" || data.status == "Booked" || data.status == "Reserved" || data.status == "Maintenance")
        && data.updatedAt is string;
    }

    function isValidSeat(data) {
      return data.keys().hasAll(['id', 'roomId', 'roomNo', 'seatNo', 'status', 'rentPrice'])
        && data.id is string && data.id.size() <= 128
        && data.roomId is string && data.roomId.size() <= 128
        && data.roomNo is string && data.roomNo.size() <= 50
        && data.seatNo is string && data.seatNo.size() <= 50
        && data.status is string && (data.status == "Available" || data.status == "Booked" || data.status == "Reserved" || data.status == "Maintenance")
        && data.rentPrice is number;
    }

    function isValidMember(data) {
      return data.keys().hasAll(['id', 'fullName', 'phone', 'nidOrStudentId', 'roomId', 'roomNo', 'seatId', 'seatNo', 'packageName', 'joiningDate', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.fullName is string && data.fullName.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.nidOrStudentId is string && data.nidOrStudentId.size() <= 100
        && data.roomId is string && data.roomId.size() <= 128
        && data.roomNo is string && data.roomNo.size() <= 50
        && data.seatId is string && data.seatId.size() <= 128
        && data.seatNo is string && data.seatNo.size() <= 50
        && data.packageName is string && (data.packageName == "Basic" || data.packageName == "Standard" || data.packageName == "Premium" || data.packageName == "VIP")
        && data.status is string && (data.status == "Active" || data.status == "Inactive");
    }

    function isValidPackage(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'foodSystem', 'mealCount', 'facilities'])
        && data.keys().size() == 6
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.price is number
        && data.foodSystem is string && data.foodSystem.size() <= 100
        && data.mealCount is int
        && data.facilities is list;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['id', 'memberId', 'memberName', 'roomNo', 'seatNo', 'amount', 'type', 'method', 'month', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.memberId is string && data.memberId.size() <= 128
        && data.memberName is string && data.memberName.size() <= 200
        && data.roomNo is string && data.roomNo.size() <= 50
        && data.seatNo is string && data.seatNo.size() <= 50
        && data.amount is number
        && data.type is string && (data.type == "Rent" || data.type == "Food" || data.type == "Advance" || data.type == "Extra")
        && data.method is string && (data.method == "Cash" || data.method == "bKash" || data.method == "Nagad" || data.method == "Rocket")
        && data.month is string && data.month.size() <= 50
        && data.status is string && (data.status == "Paid" || data.status == "Pending");
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'type', 'amount', 'date'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.category is string && (data.category == "Food" || data.category == "Electricity" || data.category == "Gas" || data.category == "WiFi" || data.category == "Salary" || data.category == "Maintenance" || data.category == "Others")
        && data.type is string && (data.type == "Expense" || data.type == "Income")
        && data.amount is number
        && data.date is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'title', 'message', 'type', 'read'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.type is string && (data.type == "Due" || data.type == "Payment" || data.type == "Vacancy" || data.type == "General")
        && data.read is bool;
    }

    // Collection Security Match Rules
    
    // Admin users
    match /admins/{adminId} {
      allow read: if true;
      allow create, update: if isValidId(adminId) && isValidAdmin(request.resource.data);
      allow delete: if true;
    }

    // Rooms match block
    match /rooms/{roomId} {
      allow read: if true;
      allow create, update: if isValidId(roomId) && isValidRoom(request.resource.data);
      allow delete: if true;
    }

    // Seats match block
    match /seats/{seatId} {
      allow read: if true;
      allow create, update: if isValidId(seatId) && isValidSeat(request.resource.data);
      allow delete: if true;
    }

    // Members match block
    match /members/{memberId} {
      allow read: if true;
      allow create, update: if isValidId(memberId) && isValidMember(request.resource.data);
      allow delete: if true;
    }

    // Packages match block
    match /packages/{packageId} {
      allow read: if true;
      allow create, update: if isValidId(packageId) && isValidPackage(request.resource.data);
      allow delete: if true;
    }

    // Payments match block
    match /payments/{paymentId} {
      allow read: if true;
      allow create, update: if isValidId(paymentId) && isValidPayment(request.resource.data);
      allow delete: if true;
    }

    // Expenses match block
    match /expenses/{expenseId} {
      allow read: if true;
      allow create, update: if isValidId(expenseId) && isValidExpense(request.resource.data);
      allow delete: if true;
    }

    // Notifications match block
    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update: if isValidId(notificationId) && isValidNotification(request.resource.data);
      allow delete: if true;
    }

  }
}
